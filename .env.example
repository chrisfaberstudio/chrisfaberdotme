# Sanity project — create at sanity.io or via: cd studio && npx sanity@latest init
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production

# Only needed for running the seed script (scripts/seed.ts)
# Create a token at sanity.io → project → API → Tokens (Editor role)
SANITY_API_WRITE_TOKEN=
